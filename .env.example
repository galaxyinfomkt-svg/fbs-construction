# ── Contact form email delivery ───────────────────────────────────────────────
# The form works with EITHER option below. If neither is set, submissions are
# logged to the Vercel function logs and the form still confirms success.

# Option A — Web3Forms (easiest: no domain, free). Get a key at https://web3forms.com
# by entering fbsconstruction@hotmail.com; the access key is emailed to that inbox.
WEB3FORMS_ACCESS_KEY=

# Option B — Resend (https://resend.com). Best with a verified sending domain.
RESEND_API_KEY=
CONTACT_FROM_EMAIL=FBS Construction <estimates@fbsconstructioninc.com>

# Where estimate requests are delivered (defaults to the business email):
CONTACT_TO_EMAIL=fbsconstruction@hotmail.com
