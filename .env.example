# Optional: connect the contact form to email delivery via Resend (https://resend.com).
# If these are not set, submissions are logged to the server function logs and the
# form still returns success to the user.

RESEND_API_KEY=
# Where estimate requests are delivered (defaults to the business email):
CONTACT_TO_EMAIL=fbsconstruction@hotmail.com
# Verified sender on your Resend account (must be a domain you verified):
CONTACT_FROM_EMAIL=FBS Construction <estimates@fbsconstructioninc.com>
